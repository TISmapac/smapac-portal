# ============================================================================
# SMAPAC — smapac.gob.mx
# Portal estático (Next.js export) en la raíz + apps en subcarpetas
# (pagaturecibo/, intranet/), servidos por Apache en DonWeb/Ferozo.
#
# Este archivo vive en public/.htaccess del repo: el build lo copia a out/
# y se sube a la raíz de public_html junto con el resto del sitio.
# Incorpora las reglas del .htaccess del sitio anterior (HTTPS condicionado
# a Cloudflare y redirección de /smapac2/Directorio.html).
# ============================================================================

RewriteEngine On

# ----------------------------------------------------------------------------
# HTTPS para accesos directos al origen (heredado del sitio anterior).
# Cloudflare ya redirige http→https en el borde; esta regla solo actúa cuando
# la petición NO viene de Cloudflare (sin header CDN-LOOP), por eso no
# provoca bucles de redirección.
# ----------------------------------------------------------------------------
RewriteCond %{HTTPS} off
RewriteCond %{HTTP:CDN-LOOP} !cloudflare
RewriteCond %{REQUEST_URI} !^/\.well-known/acme-challenge/
RewriteCond %{HTTP_HOST} ^(www\.)?smapac\.gob\.mx
RewriteRule (.*) https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L,QSA]

# Redirección heredada: enlace antiguo del directorio de transparencia
RewriteRule ^smapac2/Directorio\.html$ /transparencia-web/directorio_smapac.html [R=301,L]

# ----------------------------------------------------------------------------
# MODO MANTENIMIENTO (desactivado). Para activarlo, descomenta las 3 líneas.
# Deja pasar solo a la IP de oficina (ajústala si cambia) y a la propia
# página /mantenimiento.html (incluida en el build, sin assets externos).
# ----------------------------------------------------------------------------
# RewriteCond %{REQUEST_URI} !/mantenimiento\.html$
# RewriteCond %{REMOTE_ADDR} !^189\.238\.234\.221$
# RewriteRule .* /mantenimiento.html [R=302,L]

# Página de error 404 generada por Next
ErrorDocument 404 /404.html

# No listar el contenido de carpetas sin index
# (si el hosting devolviera "500 Internal Server Error", eliminar esta línea)
Options -Indexes

# Codificación por defecto
AddDefaultCharset utf-8

# ----------------------------------------------------------------------------
# Cache
# ----------------------------------------------------------------------------
<IfModule mod_headers.c>
  # Los bundles de Next (/_next/) llevan hash en el nombre: cache de 1 año
  <If "%{REQUEST_URI} =~ m#^/_next/#">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </If>

  # El HTML siempre se revalida (su nombre no cambia entre despliegues).
  # Aplica también al index.html de pagaturecibo/ e intranet/, lo cual les
  # conviene: sus bundles Angular también llevan hash.
  <FilesMatch "\.html$">
    Header set Cache-Control "no-cache"
  </FilesMatch>
</IfModule>

<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType image/webp    "access plus 1 month"
  ExpiresByType image/png     "access plus 1 month"
  ExpiresByType image/jpeg    "access plus 1 month"
  ExpiresByType image/svg+xml "access plus 1 month"
  ExpiresByType image/x-icon  "access plus 1 month"
  ExpiresByType font/woff2    "access plus 1 year"
</IfModule>

# ----------------------------------------------------------------------------
# Compresión
# ----------------------------------------------------------------------------
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/css application/javascript application/json image/svg+xml
</IfModule>
